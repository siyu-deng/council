{
  "name": "@moyu-build/council",
  "version": "0.3.1",
  "description": "Council — 你的思考议会。捕获对话, 蒸馏思维 skill, 召集多 persona 辩论。CLI + MCP server, 跨 Claude Desktop / Cursor / Claude Code 通用。",
  "keywords": [
    "council",
    "mcp",
    "mcp-server",
    "claude",
    "ai",
    "thinking",
    "personas",
    "cli",
    "anthropic"
  ],
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "墨宇 (Siyu Deng)",
    "email": "bozzkopp791@gmail.com"
  },
  "homepage": "https://github.com/siyu-deng/council#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/siyu-deng/council.git"
  },
  "bugs": {
    "url": "https://github.com/siyu-deng/council/issues"
  },
  "bin": {
    "council": "./dist/council.mjs"
  },
  "files": [
    "dist",
    "seeds",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "bun run bin/council.ts",
    "build": "tsdown",
    "build:check": "node dist/council.mjs --version",
    "prepublishOnly": "npm run build && npm run build:check",
    "mcp:dev": "bun run src/mcp/server.ts",
    "preflight": "bash scripts/preflight.sh",
    "preflight:mock": "bash scripts/preflight.sh --mock",
    "preflight:fast": "bash scripts/preflight.sh --skip-convene"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "boxen": "^8.0.1",
    "clipboardy": "^4.0.0",
    "commander": "^12.1.0",
    "gray-matter": "^4.0.3",
    "kleur": "^4.1.5",
    "ora": "^8.1.1",
    "ws": "^8.20.0",
    "yaml": "^2.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/ws": "^8.18.1",
    "tsdown": "^0.21.10",
    "typescript": "^5.6.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
